import heapq

def scheduleCourse(courses: list[list[int]]) -> int:
    # Sort courses by their deadlines
    courses.sort(key=lambda x: x[1])
    max_heap = []
    current_time = 0
    
    for duration, deadline in courses:
        current_time += duration
        heapq.heappush(max_heap, -duration) # Max-heap using negative numbers
        
        # If deadline is breached, drop the course that took up the most time
        if current_time > deadline:
            longest_duration = -heapq.heappop(max_heap)
            current_time -= longest_duration
            
    return len(max_heap)
