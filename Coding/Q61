def uniquePaths(m: int, n: int) -> int:
    # Initialize the bottom row with 1s
    row = [1] * n
    
    # Run loops to update previous grid row calculations
    for _ in range(m - 1):
        new_row = [1] * n
        for c in range(n - 2, -1, -1):
            new_row[c] = new_row[c + 1] + row[c]
        row = new_row
        
    return row[0]
