def reverseKGroup(head: ListNode, k: int) -> ListNode:
    # Check if there are at least k nodes left
    curr = head
    count = 0
    while curr and count < k:
        curr = curr.next
        count += 1
        
    if count == k:
        # Reverse k nodes
        prev = None
        curr = head
        for _ in range(k):
            nxt = curr.next
            curr.next = prev
            prev = curr
            curr = nxt
            
        # head is now the tail of our reversed group, link it to the next processed group
        if curr:
            head.next = reverseKGroup(curr, k)
            
        return prev # New head of this reversed k-group
        
    return head
