def canCompleteCircuit(gas: list[int], cost: list[int]) -> int:
    total_surplus = 0
    current_surplus = 0
    start_station = 0
    
    for i in range(len(gas)):
        diff = gas[i] - cost[i]
        total_surplus += diff
        current_surplus += diff
        
        # If your car runs empty, the starting station cannot be anywhere up to i
        if current_surplus < 0:
            start_station = i + 1
            current_surplus = 0
            
    return start_station if total_surplus >= 0 else -1
