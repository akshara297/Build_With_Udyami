def subsetsWithDup(nums: list[int]) -> list[list[int]]:
    res = []
    nums.sort()
    
    def backtrack(start, path):
        res.append(path[:])
        
        for i in range(start, len(nums)):
            # If it's a duplicate in the same recursion level, skip it
            if i > start and nums[i] == nums[i - 1]:
                continue
            path.append(nums[i])
            backtrack(i + 1, path)
            path.pop()
            
    backtrack(0, [])
    return res
