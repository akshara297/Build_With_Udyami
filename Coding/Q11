def productExceptSelf(nums: list[int]) -> list[int]:
    n = len(nums)
    res = [1] * n
    
    # Left products
    for i in range(1, n):
        res[i] = res[i - 1] * nums[i - 1]
        
    # Right products calculated on the fly
    right_prod = 1
    for i in range(n - 1, -1, -1):
        res[i] *= right_prod
        right_prod *= nums[i]
        
    return res
