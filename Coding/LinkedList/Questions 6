class AdvancedWindowHeapSolutions:
    
    # =========================================================================
    # 1. Subarrays with K Different Integers (Sliding Window Helper)
    # Time Complexity: O(N) | Space Complexity: O(N)
    # =========================================================================
    def subarraysWithKDistinct(self, nums: list[int], k: int) -> int:
        # The Core Mathematical Insight: Exactly(K) = AtMost(K) - AtMost(K - 1)
        return self.atMostK(nums, k) - self.atMostK(nums, k - 1)
        
    def atMostK(self, nums: list[int], k: int) -> int:
        freq = {}
        left = 0
        count = 0
        
        for right, num in enumerate(nums):
            freq[num] = freq.get(num, 0) + 1
            
            # If our window has more than K distinct elements, shrink it from the left
            while len(freq) > k:
                freq[nums[left]] -= 1
                if freq[nums[left]] == 0:
                    del freq[nums[left]]
                left += 1
                
            # The number of valid subarrays ending at 'right' is equal to the window size
            count += (right - left + 1)
            
        return count

    # =========================================================================
    # 2. Minimum Window Substring (Two Pointers / Sliding Window)
    # Time Complexity: O(N + M) | Space Complexity: O(M) where N=len(s), M=len(t)
    # =========================================================================
    def minWindow(self, s: str, t: str) -> str:
        if not s or not t:
            return ""
            
        target_counts = Counter(t)
        window_counts = {}
        
        # 'required' is the number of unique characters in t that must match in frequency
        required = len(target_counts)
        # 'formed' tracks how many unique characters match the target frequencies so far
        formed = 0
        
        left = 0
        # Stores the tuple: (window_length, left_idx, right_idx)
        ans = (float('inf'), None, None)
        
        for right, char in enumerate(s):
            window_counts[char] = window_counts.get(char, 0) + 1
            
            # If the frequency of the current character matches its target frequency
            if char in target_counts and window_counts[char] == target_counts[char]:
                formed += 1
                
            # Contract the window from the left as long as the constraints are satisfied
            while left <= right and formed == required:
                char_left = s[left]
                
                # Update our minimal window result tracking boundaries
                if right - left + 1 < ans[0]:
                    ans = (right - left + 1, left, right)
                    
                window_counts[char_left] -= 1
                if char_left in target_counts and window_counts[char_left] < target_counts[char_left]:
                    formed -= 1
                    
                left += 1
                
        return "" if ans[0] == float('inf') else s[ans[1]:ans[2] + 1]

    # =========================================================================
    # 4. Course Schedule III (Greedy Choice Property + Max Heap Eviction)
    # Time Complexity: O(N log N) | Space Complexity: O(N)
    # =========================================================================
    def scheduleCourse(self, courses: list[list[int]]) -> int:
        # Step 1: Sort courses strictly by their deadlines
        courses.sort(key=lambda x: x[1])
        
        max_heap = [] # Stores course durations. Inverted to act as a Max-Heap in Python.
        total_time = 0
        
        for duration, deadline in courses:
            # Add course to the current schedule tracking timeline
            total_time += duration
            heapq.heappush(max_heap, -duration)
            
            # If the cumulative timeline breaks the current deadline constraint,
            # retroactively evict the longest course taken so far to free up maximum buffer space.
            if total_time > deadline:
                longest_duration = -heapq.heappop(max_heap)
                total_time -= longest_duration
                
        return len(max_heap)


