from collections import deque, defaultdict

class AdvancedGraphSolutions:
    
    # =========================================================================
    # 1. Critical Connections in a Network (Tarjan's Bridge-Finding Algorithm)
    # Time Complexity: O(V + E) | Space Complexity: O(V + E)
    # =========================================================================
    def criticalConnections(self, n: int, connections: list[list[int]]) -> list[list[int]]:
        # Build adjacency list
        graph = defaultdict(list)
        for u, v in connections:
            graph[u].append(v)
            graph[v].append(u)
            
        # rank[i] stores the discovery time of node i
        # low[i] stores the lowest rank reachable from node i via back-edges
        rank = [-1] * n
        low = [-1] * n
        bridges = []
        
        def dfs(node: int, parent: int, discovery_time: int):
            rank[node] = low[node] = discovery_time
            
            for neighbor in graph[node]:
                if neighbor == parent:
                    continue
                
                if rank[neighbor] == -1:
                    # Neighbor hasn't been visited; recurse down the DFS tree
                    dfs(neighbor, node, discovery_time + 1)
                    
                    # Upon return, update low-link value of the current node
                    low[node] = min(low[node], low[neighbor])
                    
                    # If neighbor cannot reach back to 'node' or any ancestral node, 
                    # the edge between them is a bridge.
                    if low[neighbor] > rank[node]:
                        bridges.append([node, neighbor])
                else:
                    # Neighbor is already visited; it's a back-edge. Update low-link.
                    low[node] = min(low[node], rank[neighbor])
                    
        dfs(0, -1, 0)
        return bridges

    # =========================================================================
    # 2. Word Ladder II (BFS Layering + DFS Backtracking)
    # Time Complexity: O(N * 26^L + Total Paths) | Space Complexity: O(N * L)
    # =========================================================================
    def findLadders(self, beginWord: str, endWord: str, wordList: list[str]) -> list[list[str]]:
        word_set = set(wordList)
        if endWord not in word_set:
            return []
            
        # Step 1: BFS to find the shortest distance from beginWord to all reachable words
        # and map valid directed parent-to-child edges that belong to the shortest paths.
        word_set.discard(beginWord)
        adj_graph = defaultdict(list)
        distance = {beginWord: 0}
        
        queue = deque([beginWord])
        found = False
        
        while queue and not found:
            visited_this_level = set()
            for _ in range(len(queue)):
                curr_word = queue.popleft()
                curr_dist = distance[curr_word]
                
                # Generate all possible single-letter mutations
                for i in range(len(curr_word)):
                    original_char = curr_word[i]
                    for c in 'abcdefghijklmnopqrstuvwxyz':
                        if c == original_char:
                            continue
                        next_word = curr_word[:i] + c + curr_word[i+1:]
                        
                        if next_word in word_set:
                            # If it's a new word or visited at the current level (same short path length)
                            if next_word not in distance or distance[next_word] == curr_dist + 1:
                                if next_word not in distance:
                                    distance[next_word] = curr_dist + 1
                                    queue.append(next_word)
                                    visited_this_level.add(next_word)
                                
                                # Record transition for path reconstruction
                                adj_graph[curr_word].append(next_word)
                                if next_word == endWord:
                                    found = True
                                    
            # Remove words visited in this level from the available set so they aren't reused later
            for word in visited_this_level:
                word_set.discard(word)
                
        if not found:
            return []
            
        # Step 2: DFS backtracking to extract all paths using our generated adj_graph
        results = []
        
        def backtrack(word: str, path: list[str]):
            if word == endWord:
                results.append(list(path))
                return
            for next_word in adj_graph[word]:
                path.append(next_word)
                backtrack(next_word, path)
                path.pop()
                
        backtrack(beginWord, [beginWord])
        return results

    # =========================================================================
    # 3. Longest Path With Different Adjacent Characters (Tree DP)
    # Time Complexity: O(V) | Space Complexity: O(V)
    # =========================================================================
    def longestPath(self, parent: list[int], s: str) -> int:
        n = len(parent)
        children = defaultdict(list)
        for i in range(1, n):
            children[parent[i]].append(i)
            
        self.global_max = 0
        
        def dfs(node: int) -> int:
            # Tracks the top two longest paths extending from this node into its children
            max1, max2 = 0, 0
            
            for child in children[node]:
                child_path_len = dfs(child)
                
                # Valid transition rule: Adjacent characters must differ
                if s[node] != s[child]:
                    if child_path_len > max1:
                        max2 = max1
                        max1 = child_path_len
                    elif child_path_len > max2:
                        max2 = child_path_len
                        
            # Update the global longest path passing through this node as a turning point
            self.global_max = max(self.global_max, max1 + max2 + 1)
            
            # Return the single longest valid branch extending upward to the parent node
            return max1 + 1
            
        dfs(0)
        return self.global_max

    # =========================================================================
    # 4. Optimize Water Distribution in a Village (Virtual Node MST / Kruskal)
    # Time Complexity: O(E log E) | Space Complexity: O(V + E)
    # =========================================================================
    def supplyWater(self, n: int, wells: list[int], pipes: list[list[int]]) -> int:
        # Union-Find (Disjoint Set Union) data structure for Kruskal's algorithm
        parent = list(range(n + 1))
        
        def find(i):
            if parent[i] == i:
                return i
            parent[i] = find(parent[i])  # Path compression
            return parent[i]
            
        def union(i, j):
            root_i = find(i)
            root_j = find(j)
            if root_i != root_j:
                parent[root_i] = root_j
                return True
            return False

        edges = []
        
        # The Breakthrough: Transform well drilling into an edge from virtual Node 0
        for i, cost in enumerate(wells):
            edges.append((cost, 0, i + 1))
            
        # Add normal piping connections
        for u, v, cost in pipes:
            edges.append((cost, u, v))
            
        # Kruskal's Algorithm: Sort edges by cost
        edges.sort()
        
        total_cost = 0
        edges_used = 0
        
        for cost, u, v in edges:
            if union(u, v):
                total_cost += cost
                edges_used += 1
                # An MST containing 'n' houses + 1 virtual node will have exactly 'n' edges
                if edges_used == n:
                    break
                    
        return total_cost

