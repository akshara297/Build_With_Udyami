class AdvancedStringBitSolutions:
    
    # =========================================================================
    # 1. Shortest Palindrome (KMP / Longest Prefix-Suffix Array)
    # Time Complexity: O(N) | Space Complexity: O(N)
    # =========================================================================
    def shortestPalindrome(self, s: str) -> str:
        if not s:
            return s
            
        # Create a combined string: s + special_sentinel + reverse(s)
        # The sentinel '#' ensures our KMP table doesn't match beyond the boundaries of s
        rev_s = s[::-1]
        combined = s + '#' + rev_s
        
        # Build KMP Lookup Table (Partial Match / LPS Array)
        lps = [0] * len(combined)
        for i in range(1, len(combined)):
            j = lps[i - 1]
            while j > 0 and combined[i] != combined[j]:
                j = lps[j - 1]
            if combined[i] == combined[j]:
                j += 1
            lps[i] = j
            
        # lps[-1] now gives us the length of the longest palindromic prefix in s
        longest_palindrome_prefix_len = lps[-1]
        
        # Take the non-palindromic suffix, reverse it, and attach it to the front
        remaining_suffix = s[longest_palindrome_prefix_len:]
        return remaining_suffix[::-1] + s

    # =========================================================================
    # 2. Number of Valid Words for Each Puzzle (Bitmasking + Subset Iteration)
    # Time Complexity: O(Words * L + Puzzles * 2^7) | Space Complexity: O(Words)
    # =========================================================================
    def findNumOfValidWords(self, words: list[str], puzzles: list[str]) -> list[int]:
        # Frequency map to store occurrences of each unique word bitmask
        mask_counts = {}
        
        for word in words:
            mask = 0
            for char in word:
                mask |= (1 << (ord(char) - ord('a')))
                
            # A puzzle only has 7 unique characters. Any word with more than 7 
            # unique characters can never be formed by a puzzle.
            if bin(mask).count('1') <= 7:
                mask_counts[mask] = mask_counts.get(mask, 0) + 1
                
        results = []
        
        for puzzle in puzzles:
            # Generate the baseline bitmask for the entire puzzle
            puzzle_mask = 0
            for char in puzzle:
                puzzle_mask |= (1 << (ord(char) - ord('a')))
                
            # The first character of the puzzle must be present in the word
            first_char_mask = 1 << (ord(puzzle[0]) - ord('a'))
            
            # Optimized Bitwise Subset Iteration technique:
            # Loop through all subsets of the puzzle_mask
            sub_mask = puzzle_mask
            valid_count = 0
            
            while sub_mask > 0:
                # Check if the current subset contains the puzzle's first character
                if (sub_mask & first_char_mask) == first_char_mask:
                    if sub_mask in mask_counts:
                        valid_count += mask_counts[sub_mask]
                        
                # Standard bitwise trick to extract the next sub-mask pattern smoothly
                sub_mask = (sub_mask - 1) & puzzle_mask
                
            results.append(valid_count)
            
        return results

    # =========================================================================
    # 3. Regular Expression Matching (2D Top-Down Memoized DP)
    # Time Complexity: O(T * P) | Space Complexity: O(T * P) where T=text, P=pattern
    # =========================================================================
    def isMatch(self, text: str, pattern: str) -> bool:
        memo = {}
        
        def dp(i: int, j: int) -> bool:
            # Check cache
            if (i, j) in memo:
                return memo[(i, j)]
                
            # Base Case: If we reach the end of the pattern, text must also be exhausted
            if j == len(pattern):
                return i == len(text)
                
            # Check if current characters match, taking '.' wildcard into account
            first_match = (i < len(text) and pattern[j] in {text[i], '.'})
            
            # Case handling when the next character in pattern is a '*' wildcard
            if j + 1 < len(pattern) and pattern[j + 1] == '*':
                # Choice 1: Ignore the '*' pattern completely (match 0 times) -> dp(i, j+2)
                # Choice 2: Use the '*' if current characters match (match 1+ times) -> dp(i+1, j)
                ans = dp(i, j + 2) or (first_match and dp(i + 1, j))
            else:
                # Normal linear matching path
                ans = first_match and dp(i + 1, j + 1)
                
            memo[(i, j)] = ans
            return ans
            
        return dp(0, 0)


