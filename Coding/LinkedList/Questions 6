# 3. Find Median from Data Stream (Balanced Two Heaps Structure)
# Time Complexity: Add: O(log N), Find: O(1) | Space Complexity: O(N)
# =========================================================================
class MedianFinder:

    def __init__(self):
        # max_heap stores the smaller half of numbers (inverted to handle python min-heap natively)
        self.max_heap = []
        # min_heap stores the larger half of numbers
        self.min_heap = []

    def addNum(self, num: int) -> None:
        # Push to max_heap first, then move the highest of the lower group to min_heap
        heapq.heappush(self.max_heap, -num)
        heapq.heappush(self.min_heap, -heapq.heappop(self.max_heap))
        
        # Maintain structural balance: max_heap can have at most 1 more element than min_heap
        if len(self.max_heap) < len(self.min_heap):
            heapq.heappush(self.max_heap, -heapq.heappop(self.min_heap))

    def findMedian(self) -> float:
        if len(self.max_heap) > len(self.min_heap):
            return float(-self.max_heap[0])
        # If balanced evenly, return the average of the roots of both heaps
        return (-self.max_heap[0] + self.min_heap[0]) / 2.0


