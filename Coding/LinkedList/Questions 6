# 4. Prefix and Suffix Search (Suffix-Wrapped Trie)
# Time Complexity: Initialization: O(N * L^2), Query: O(Prefix + Suffix)
# Space Complexity: O(N * L^2) where L is the maximum length of a word
# =========================================================================
class TrieNode:
    def __init__(self):
        self.children = {}
        self.weight = -1  # Stores the highest index of the word matching this state

class WordFilter:
    def __init__(self, words: list[str]):
        self.root = TrieNode()
        
        # Loop through words; tracking weight (index)
        for weight, word in enumerate(words):
            # The Twist: Insert permutations like "suffix + '{' + prefix" into the Trie
            # '{' is chosen because its ASCII value is immediately after 'z'
            wrapped_word = word + '{' + word
            length = len(word)
            
            # Insert every possible suffix slice combination starting up to the sentinel character '{'
            for i in range(length + 1):
                curr = self.root
                curr.weight = weight
                
                # Insert the wrapped suffix pattern down into the Trie nodes
                for char in wrapped_word[i:]:
                    if char not in curr.children:
                        curr.children[char] = TrieNode()
                    curr = curr.children[char]
                    curr.weight = weight

    def f(self, prefix: str, suffix: str) -> int:
        curr = self.root
        # Transform the target lookup to match our Trie topology
        query = suffix + '{' + prefix
        
        for char in query:
            if char not in curr.children:
                return -1
            curr = curr.children[char]
            
        return curr.weight


