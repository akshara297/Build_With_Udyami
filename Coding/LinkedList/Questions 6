# DAY 3: Prefix Sum & Kadane’s Algorithm
# =============================================================================
class Day3PrefixSumKadane:

    # 1. Find pivot index
    # Time Complexity: O(N) | Space Complexity: O(1)
    def pivotIndex(self, nums: list[int]) -> int:
        total_sum = sum(nums)
        left_sum = 0
        
        for i, num in enumerate(nums):
            if left_sum == (total_sum - left_sum - num):
                return i
            left_sum += num
        return -1

    # 2. Maximum Subarray Sum (Kadane's Algorithm)
    # Time Complexity: O(N) | Space Complexity: O(1)
    def maxSubArray(self, nums: list[int]) -> int:
        max_so_far = nums[0]
        current_max = nums[0]
        
        for i in range(1, len(nums)):
            current_max = max(nums[i], current_max + nums[i])
            max_so_far = max(max_so_far, current_max)
            
        return max_so_far

    # 3. Product of array except self
    # Time Complexity: O(N) | Space Complexity: O(1) output array optimization
    def productExceptSelf(self, nums: list[int]) -> list[int]:
        n = len(nums)
        ans = [1] * n
        
        # prefix computation passes from left to right
        for i in range(1, n):
            ans[i] = ans[i - 1] * nums[i - 1]
            
        # suffix computation passes from right to left dynamically
        right_prod = 1
        for i in range(n - 1, -1, -1):
            ans[i] *= right_prod
            right_prod *= nums[i]
            
        return ans

    # 4. Subarray sum equals K (Prefix sum + Hash map)
    # Time Complexity: O(N) | Space Complexity: O(N)
    def subarraySum(self, nums: list[int], k: int) -> int:
        prefix_counts = {0: 1} # Base case configuration
        current_sum = 0
        count = 0
        
        for num in nums:
            current_sum += num
            # Check if matching remainder context exists
            if (current_sum - k) in prefix_counts:
                count += prefix_counts[current_sum - k]
            prefix_counts[current_sum] = prefix_counts.get(current_sum, 0) + 1
            
        return count


