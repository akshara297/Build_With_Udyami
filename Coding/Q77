def canCompleteCircuit(gas: list[int], cost: list[int]) -> int:
    if sum(gas) < sum(cost): return -1
    
    total_tank = 0
    start_index = 0
    
    for i in range(len(gas)):
        total_tank += gas[i] - cost[i]
        
        # If running empty, reset starting guess to the next station
        if total_tank < 0:
            start_index = i + 1
            total_tank = 0
            
    return start_index
