def rob_linear(nums):
    rob1, rob2 = 0, 0
    for num in nums:
        new_rob = max(rob1 + num, rob2)
        rob1 = rob2
        rob2 = new_rob
    return rob2

def rob(nums: list[int]) -> int:
    if len(nums) == 1: return nums[0]
    # Take max of excluding last house or excluding first house
    return max(rob_linear(nums[:-1]), rob_linear(nums[1:]))
