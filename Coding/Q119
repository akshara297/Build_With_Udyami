def findClosestElements(arr: list[int], k: int, x: int) -> list[int]:
    # Binary search bounds for the starting point of the window
    left, right = 0, len(arr) - k
    
    while left < right:
        mid = (left + right) // 2
        # Compare distances to determine if mid or mid + k is closer to x
        if x - arr[mid] > arr[mid + k] - x:
            left = mid + 1
        else:
            right = mid
            
    return arr[left : left + k]
