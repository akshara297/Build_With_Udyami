def removeNthFromEnd(head: ListNode, n: int) -> ListNode:
    dummy = ListNode(0, head)
    left = dummy
    right = head
    
    # Advance right pointer by n steps
    for _ in range(n):
        right = right.next
        
    # Advance both until right hits the end
    while right:
        left = left.next
        right = right.next
        
    # Delete the node
    left.next = left.next.next
    return dummy.next
