def subarraySum(nums: list[int], k: int) -> int:
    res = 0
    curr_sum = 0
    prefix_sums = {0: 1} # Base case: an empty prefix sum of 0 has seen 1 time
    
    for num in nums:
        curr_sum += num
        diff = curr_sum - k
        
        res += prefix_sums.get(diff, 0)
        prefix_sums[curr_sum] = prefix_sums.get(curr_sum, 0) + 1
        
    return res
