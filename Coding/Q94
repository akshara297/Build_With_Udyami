import random

class RandomizedSet:
    def __init__(self):
        self.num_list = []
        self.pos_map = {} # Maps value to its index in num_list

    def insert(self, val: int) -> bool:
        if val in self.pos_map:
            return False
        self.pos_map[val] = len(self.num_list)
        self.num_list.append(val)
        return True

    def remove(self, val: int) -> bool:
        if val not in self.pos_map:
            return False
            
        # Move the last element to the place of the element to delete
        idx_to_remove = self.pos_map[val]
        last_val = self.num_list[-1]
        
        self.num_list[idx_to_remove] = last_val
        self.pos_map[last_val] = idx_to_remove
        
        # Pop off the redundant duplicate tail node
        self.num_list.pop()
        del self.pos_map[val]
        return True

    def getRandom(self) -> int:
        return random.choice(self.num_list)
