class Solution {
public:
    bool isAnagram(string s, string t) {
      unordered_map <char, int> seen;
    if (s.length() != t.length()){
        return false;
    }
    for( int i=0;i<s.length(); i++){
        seen[s[i]]++;
    }
    for( int j=0; j<t.length(); j++){
        seen[t[j]]--;
    }
    for( auto pair: seen){
        if( pair.second !=0){
            return false;
        }
    }
    return true;
    }
};