import math

def minEatingSpeed(piles: list[int], h: int) -> int:
    left, right = 1, max(piles)
    res = right
    
    while left <= right:
        k = (left + right) // 2
        hours_spent = 0
        
        for pile in piles:
            hours_spent += math.ceil(pile / k)
            
        if hours_spent <= h:
            res = k
            right = k - 1 # Try to find an even smaller valid speed
        else:
            left = k + 1  # Speed is too slow, increase it
            
    return res
