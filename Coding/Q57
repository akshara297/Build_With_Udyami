def alienOrder(words: list[str]) -> str:
    adj = {char: set() for w in words for char in w}
    
    for i in range(len(words) - 1):
        w1, w2 = words[i], words[i + 1]
        min_len = min(len(w1), len(w2))
        # Edge case: Check if a prefix is incorrectly sorted before a longer word
        if len(w1) > len(w2) and w1[:min_len] == w2[:min_len]:
            return ""
        for j in range(min_len):
            if w1[j] != w2[j]:
                adj[w1[j]].add(w2[j])
                break
                
    visiting, visited = {}, set()
    res = []
    
    def dfs(char):
        if char in visiting:
            return visiting[char] # True means cycle detected
        if char in visited:
            return False
            
        visiting[char] = True
        for neighbor in adj[char]:
            if dfs(neighbor): return True
        visiting[char] = False
        visited.add(char)
        res.append(char)
        return False

    for char in adj:
        if dfs(char): return ""
        
    res.reverse()
    return "".join(res)
